{
  "name": "@alexrebula/giselle-ui",
  "version": "0.1.0",
  "description": "Clean, accessible, theme-ready React component library for the Giselle brand.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "clean": "rm -rf dist storybook-static",
    "build": "tsup && npm run build:styles",
    "build:styles": "mkdir -p dist && cp src/styles.css dist/styles.css",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexRebula/giselle-ui.git"
  },
  "bugs": {
    "url": "https://github.com/AlexRebula/giselle-ui/issues"
  },
  "homepage": "https://github.com/AlexRebula/giselle-ui#readme",
  "keywords": [
    "react",
    "typescript",
    "component-library",
    "ui",
    "design-system",
    "storybook"
  ],
  "author": "Alex Rebula",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^8.6.18",
    "tsup": "^8.5.1",
    "typescript": "5.9",
    "vite": "^6.4.2"
  }
}
